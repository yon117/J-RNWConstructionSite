import { useRef, useState } from 'react';
import gsap from 'gsap';
import styles from './InteractiveHouse.module.css';

const EXTERIOR_HOTSPOTS = [
  { id: 'reconstruction', label: 'Reconstruction',    x: '20%', y: '30%' },
  { id: 'remodeling',     label: 'Remodeling',         x: '50%', y: '22%' },
  { id: 'siding',         label: 'Siding',             x: '78%', y: '40%' },
  { id: 'vinyl',          label: 'Vinyl Windows',      x: '62%', y: '56%' },
  { id: 'painting',       label: 'Painting',           x: '34%', y: '62%' },
  { id: 'emergency',      label: 'Emergency Services', x: '14%', y: '70%' },
];

const INTERIOR_HOTSPOTS = [
  { id: 'drywall',           label: 'Drywall',          x: '24%', y: '38%' },
  { id: 'remodeling-in',     label: 'Remodeling',       x: '55%', y: '26%' },
  { id: 'reconstruction-in', label: 'Reconstruction',   x: '73%', y: '52%' },
  { id: 'mitigation',        label: 'Mitigation',       x: '40%', y: '66%' },
  { id: 'restoration',       label: 'Restoration',      x: '18%', y: '58%' },
];

function Hotspot({ label, x, y }) {
  const [hovered, setHovered] = useState(false);
  return (
    <div
      className={styles.hotspot}
      style={{ left: x, top: y }}
      onMouseEnter={() => setHovered(true)}
      onMouseLeave={() => setHovered(false)}
      onFocus={() => setHovered(true)}
      onBlur={() => setHovered(false)}
      tabIndex={0}
      role="button"
      aria-label={label}
    >
      <span className={styles.dot} />
      <span className={styles.pulse} />
      {hovered && <span className={styles.tooltip}>{label}</span>}
    </div>
  );
}

export default function InteractiveHouse() {
  const [mode, setMode] = useState('exterior');
  const extRef = useRef(null);
  const intRef = useRef(null);
  const isAnimating = useRef(false);

  const enterInterior = () => {
    if (isAnimating.current || mode === 'interior') return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) { setMode('interior'); return; }

    isAnimating.current = true;
    const tl = gsap.timeline({
      onComplete: () => { isAnimating.current = false; },
    });

    tl.to(extRef.current, { scale: 2.4, opacity: 0, duration: 0.65, ease: 'power2.in' })
      .call(() => setMode('interior'))
      .set(extRef.current, { scale: 1 })
      .fromTo(intRef.current, { opacity: 0, scale: 1.12 }, { opacity: 1, scale: 1, duration: 0.5, ease: 'power2.out' });
  };

  const exitInterior = () => {
    if (isAnimating.current || mode === 'exterior') return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) { setMode('exterior'); return; }

    isAnimating.current = true;
    const tl = gsap.timeline({
      onComplete: () => { isAnimating.current = false; },
    });

    tl.to(intRef.current, { scale: 0.55, opacity: 0, duration: 0.55, ease: 'power2.in' })
      .call(() => setMode('exterior'))
      .fromTo(extRef.current, { opacity: 0, scale: 0.92 }, { opacity: 1, scale: 1, duration: 0.55, ease: 'power2.out' });
  };

  const hotspots = mode === 'exterior' ? EXTERIOR_HOTSPOTS : INTERIOR_HOTSPOTS;

  return (
    <div className={styles.wrap}>
      {/* Mode toggle */}
      <div className={styles.modeBtns} role="group" aria-label="House view mode">
        <button
          className={`${styles.modeBtn} ${mode === 'exterior' ? styles.active : ''}`}
          onClick={exitInterior}
        >
          Exterior
        </button>
        <button
          className={`${styles.modeBtn} ${mode === 'interior' ? styles.active : ''}`}
          onClick={enterInterior}
        >
          Interior
        </button>
      </div>

      {/* Image container */}
      <div className={styles.imageWrap}>
        {/* Exterior */}
        <div
          ref={extRef}
          className={styles.imageLayer}
          style={{ opacity: mode === 'exterior' ? 1 : 0, pointerEvents: mode === 'exterior' ? 'auto' : 'none' }}
        >
          <img
            src="/house-exterior.jpg"
            alt="House exterior — explore our services"
            className={styles.houseImg}
          />
        </div>

        {/* Interior */}
        <div
          ref={intRef}
          className={styles.imageLayer}
          style={{ opacity: mode === 'interior' ? 1 : 0, pointerEvents: mode === 'interior' ? 'auto' : 'none' }}
        >
          <img
            src="/house-interior.jpg"
            alt="House interior — explore our services"
            className={styles.houseImg}
          />
        </div>

        {/* Hotspot overlays */}
        {hotspots.map(h => (
          <Hotspot key={h.id} label={h.label} x={h.x} y={h.y} />
        ))}

        {/* Mode label overlay */}
        <div className={styles.modeLabel}>
          {mode === 'exterior' ? 'EXTERIOR VIEW' : 'INTERIOR VIEW'}
        </div>
      </div>
    </div>
  );
}
