.wrap {
  display: flex;
  flex-direction: column;
  gap: 10px;
  user-select: none;
}

/* ── Mode toggle ── */
.modeBtns {
  display: flex;
  gap: 3px;
  background: var(--dark-mid);
  border-radius: 3px;
  padding: 3px;
  width: fit-content;
}

.modeBtn {
  padding: 7px 20px;
  border: none;
  border-radius: 2px;
  background: transparent;
  color: var(--gray);
  font-family: 'Barlow', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.18s ease;
}

.modeBtn.active {
  background: var(--gold);
  color: var(--dark);
}

/* ── Image container ── */
.imageWrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 10;
  border-radius: 3px;
  overflow: hidden;
  background: var(--dark-mid);
  border: 1px solid rgba(200, 150, 30, 0.12);
}

.imageLayer {
  position: absolute;
  inset: 0;
  will-change: transform, opacity;
}

.houseImg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Hotspots ── */
.hotspot {
  position: absolute;
  transform: translate(-50%, -50%);
  cursor: pointer;
  z-index: 10;
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hotspot:focus {
  outline: 2px solid var(--gold);
  outline-offset: 2px;
  border-radius: 50%;
}

.dot {
  display: block;
  width: 11px;
  height: 11px;
  border-radius: 50%;
  background: var(--gold);
  border: 2px solid rgba(255, 255, 255, 0.9);
  position: relative;
  z-index: 2;
  box-shadow: 0 0 0 2px rgba(200, 150, 30, 0.4);
}

.pulse {
  position: absolute;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: rgba(200, 150, 30, 0.25);
  animation: pulseRing 2.2s ease-out infinite;
  z-index: 1;
}

@keyframes pulseRing {
  0%   { transform: scale(0.55); opacity: 1; }
  100% { transform: scale(1.9);  opacity: 0; }
}

.tooltip {
  position: absolute;
  bottom: calc(100% + 6px);
  left: 50%;
  transform: translateX(-50%);
  background: rgba(15, 25, 35, 0.95);
  color: var(--white);
  font-family: 'Barlow', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: 2px;
  white-space: nowrap;
  border: 1px solid rgba(200, 150, 30, 0.35);
  pointer-events: none;
  z-index: 20;
}

/* ── Mode label ── */
.modeLabel {
  position: absolute;
  bottom: 10px;
  right: 12px;
  font-family: 'Barlow', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.5);
  z-index: 5;
  pointer-events: none;
}

/* ── Mobile ── */
@media (max-width: 768px) {
  .imageWrap {
    aspect-ratio: 4 / 3;
  }

  .hotspot {
    min-width: 48px;
    min-height: 48px;
  }

  .tooltip {
    font-size: 9px;
    padding: 4px 8px;
  }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .pulse {
    animation: none;
    opacity: 0;
  }
}
