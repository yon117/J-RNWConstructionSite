import { useRef } from 'react';
import { useGSAP } from '@gsap/react';
import gsap from 'gsap';
import WordCycler from './WordCycler';
import InteractiveHouse from './InteractiveHouse';
import styles from './HeroSection.module.css';

const HERO_LINES = [
  "Portland's #1",
  'General Contractor',
  'Serving Homes & Businesses for Over 20 Years.',
  'Remodeling · Additions · Siding · Painting.',
  'Drywall · Restoration · Mitigation · Emergency Services.',
  'Portland · Tigard · Tualatin · Gresham · Happy Valley · Oregon City',
];

export default function HeroSection({ onContactSubmit }) {
  const heroRef = useRef(null);

  useGSAP(() => {
    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      // Vertical cut-reveal on headline lines
      gsap.from(heroRef.current.querySelectorAll(`.${styles.lineInner}`), {
        y: '108%',
        duration: 0.85,
        stagger: 0.065,
        ease: 'power3.out',
        delay: 0.15,
      });

      // Word cycler fade in
      gsap.from(heroRef.current.querySelector(`.${styles.cyclerWrap}`), {
        opacity: 0,
        y: 18,
        duration: 0.6,
        delay: 0.85,
        ease: 'power2.out',
      });

      // CTA row fade in
      gsap.from(heroRef.current.querySelector(`.${styles.ctaRow}`), {
        opacity: 0,
        y: 14,
        duration: 0.55,
        delay: 1.0,
        ease: 'power2.out',
      });

      // Trust row
      gsap.from(heroRef.current.querySelector(`.${styles.trustRow}`), {
        opacity: 0,
        duration: 0.5,
        delay: 1.2,
        ease: 'power2.out',
      });

      // Right column
      gsap.from(heroRef.current.querySelector(`.${styles.rightCol}`), {
        opacity: 0,
        x: 36,
        duration: 0.9,
        delay: 0.3,
        ease: 'power3.out',
      });
    });
  }, { scope: heroRef });

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (onContactSubmit) {
      await onContactSubmit(e);
    } else {
      const data = Object.fromEntries(new FormData(e.target));
      try {
        await fetch('/api/contact', {
          method: 'POST',
          body: JSON.stringify(data),
          headers: { 'Content-Type': 'application/json' },
        });
      } catch (_) {}
      e.target.reset();
    }
  };

  return (
    <section ref={heroRef} className={styles.hero}>
      <div className={styles.grid}>

        {/* ── LEFT COLUMN ── */}
        <div className={styles.leftCol}>
          <p className={styles.eyebrow}>Licensed · Bonded · Insured · CCB #232708</p>

          <h1 className={styles.headline}>
            {HERO_LINES.map((line, i) => (
              <div key={i} className={styles.lineWrap}>
                <span className={styles.lineInner}>{line}</span>
              </div>
            ))}
          </h1>

          <div className={styles.cyclerWrap}>
            <WordCycler />
          </div>

          <div className={styles.ctaRow}>
            <a
              href="tel:+15039982340"
              className={styles.btnPrimary}
              onClick={() => {
                if (typeof window !== 'undefined' && window.gtag)
                  window.gtag('event', 'phone_click', { event_category: 'contact', event_label: 'hero' });
              }}
            >
              Call Now — Free Estimate
            </a>
            <a href="#services" className={styles.btnSecondary}>
              See Our Work
            </a>
          </div>

          <div className={styles.trustRow}>
            <span>⭐ 4.9 on Google</span>
            <span className={styles.trustDot}>·</span>
            <span>20+ Years in Portland</span>
            <span className={styles.trustDot}>·</span>
            <span>Family Owned</span>
          </div>
        </div>

        {/* ── RIGHT COLUMN ── */}
        <div className={styles.rightCol}>
          <InteractiveHouse />

          <form className={styles.quickForm} onSubmit={handleSubmit}>
            <p className={styles.formTitle}>Get a Free Estimate</p>
            <input
              name="name"
              placeholder="Your name"
              required
              className={styles.input}
              autoComplete="name"
            />
            <input
              name="phone"
              type="tel"
              placeholder="Phone number"
              required
              className={styles.input}
              autoComplete="tel"
            />
            <input
              name="email"
              type="email"
              placeholder="Email address"
              required
              className={styles.input}
              autoComplete="email"
            />
            <textarea
              name="message"
              placeholder="Describe your project…"
              rows={3}
              className={styles.textarea}
            />
            <button type="submit" className={styles.formBtn}>
              Send Request →
            </button>
          </form>
        </div>

      </div>
    </section>
  );
}
