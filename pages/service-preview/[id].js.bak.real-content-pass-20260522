                                    ))}
                                </div>
                            </div>

                            <aside className={styles.previewHeroSidebar}>
                                <div className={`${styles.previewSurface} ${styles.previewQuoteCard}`}>
                                    <span className={styles.previewPanelTag}>Preview route only</span>
                                    <h2>Organized in columns. Less flat. More alive.</h2>
                                    <p>
