function getServiceSlug(service) {
    return (
        service.slug
        || (service.title
            ? service.title
                .toLowerCase()
                .trim()
                .replace(/&/g, 'and')
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '')
            : 'service')
    );
}

function splitParagraphs(text) {
    return (text || '')
        .split('\n')
        .map((item) => item.trim())
        .filter(Boolean);
}

function withFallback(items, fallbackItems, targetCount) {
    const merged = [...items];

    for (const item of fallbackItems) {
        if (merged.length >= targetCount) {
            break;
        }
        merged.push(item);
    }

    return merged.slice(0, targetCount);
}

