        kspList.map((item) => ({
            title: item.title,
            desc: item.desc || 'Live service data can fill this panel with sharper proof copy.',
        })),
        DEFAULT_PROOF,
        3
    );
    const quoteChecklist = withFallback(
        kspList.map((item) => item.title).filter(Boolean),
        ['Licensed and insured', 'Clear scheduling', 'Clean closeout'],
        3
    );
    const faqCards = faqList.length ? faqList : DEFAULT_FAQ;
    const projectCards = (randomProjects && randomProjects.length ? randomProjects : DEFAULT_PROJECTS).slice(0, 3);
    const trustStats = [
        { value: '20+', label: 'Years experience' },
        { value: '500+', label: 'Projects completed' },
        { value: 'CCB', label: '#232708 licensed' },
        { value: 'FREE', label: 'Estimates' },
    ];
    const trustPills = ['Licensed and insured', 'Portland metro', 'Quote-first layout'];
    const serviceSlug = getServiceSlug(service);

    return (
        <Layout
            title={`Service Prototype | ${title}`}
            description={headerDesc || `Prototype preview for ${title}`}
