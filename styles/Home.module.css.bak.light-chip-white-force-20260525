}
/* Tighten section padding inside split rows */
.splitRow .projectsSection,
.splitRow .aboutSection,
.splitRow .areasSection,
.splitRow .faqSection {
  padding: 52px 40px;
}
.splitRow .aboutInner {
  flex-direction: column;
  gap: 24px;
  max-width: none;
}
.splitRow .aboutLogoWrap {
  width: auto;
}
.splitRow .projectsInner {
  max-width: none;
  padding: 0;
}
.splitRow .projectsGrid {
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 240px 240px;
}
.splitRow .projectOverlay {
  gap: 4px;
  padding: 14px 16px 16px;
}
.splitRow .projectTitle {
  font-size: 14px;
  line-height: 1.08;
  -webkit-line-clamp: 2;
}
.splitRow .projectCard.featured .projectTitle {
  font-size: 18px;
  -webkit-line-clamp: 3;
}
.splitRow .areasSection {
