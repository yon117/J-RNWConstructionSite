/* ─── HERO ───────────────────────────────────────── */
.hero {
    position: relative;
    min-height: 88vh;
    display: grid;
    align-items: start;
    justify-items: start;
    overflow: hidden;
    background: var(--dark-mid);
}

.heroInner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.9fr) minmax(320px, 456px);
    gap: 24px;
    align-items: start;
    padding: 44px 24px 72px;
    width: 100%;
    max-width: none;
    margin: 0;
    justify-items: start;
}

.heroBg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(105deg, rgba(15, 25, 35, 0.97) 45%, rgba(15, 25, 35, 0.6) 100%),
        url('/assets/home-hero-bg.webp') center / cover no-repeat;
}


.heroContent {
    position: relative;
    z-index: 2;
    padding: 0;
    max-width: none;
    min-width: 0;
}

.heroFormPanel {
    position: relative;
    z-index: 2;
    background: rgba(7, 12, 19, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 28px 26px;
    min-width: 0;
    width: 100%;
    max-width: 456px;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.35);
    align-self: start;
    margin-top: -18px;
}

.heroReviewBlock {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 10px;
    color: var(--text);
    text-align: left;
}

.heroReviewRow {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 14px;
    color: var(--white);
}

.heroReviewItems {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: nowrap;
    justify-content: flex-start;
}

.heroReviewIcon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    padding: 2px;
}

.heroReviewIcon img,
.heroReviewIcon svg {
    width: 62px;
    height: 62px;
    display: block;
}

.heroReviewStars {
    color: var(--gold);
    font-size: 28px;
    letter-spacing: 0.12em;
}

.heroReviewLabel {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
}

.heroReviewGuarantee {
    color: var(--white);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-top: 4px;
}

.heroReviewCcb {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.08em;
}

.heroBadge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(200, 150, 30, 0.12);
    border: 1px solid rgba(200, 150, 30, 0.35);
    border-radius: 2px;
    padding: 5px 14px;
    font-size: 11px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 28px;
}

.heroBadgeDot {
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse 2s infinite;
    flex-shrink: 0;
}

@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
}

.heroH1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(46px, 7vw, 78px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 24px;
    color: var(--white);
}

.heroH1 em {
    font-style: normal;
    color: var(--gold);
    display: block;
}

/* Vertical cut-reveal headline (fin.ai-inspired scale) */
.heroCutHeadline {
    margin-bottom: 4px;
}

.heroCutLineWrap {
    display: block;
    overflow: hidden;
    padding-bottom: 0.05em;
}

.heroCutLineInner {
    display: block;
    will-change: transform;
}

.heroCutLineTitle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(40px, 6.2vw, 76px);
    font-weight: 800;
    line-height: 0.96;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
}

.heroCutLineTitleAccent {
    color: var(--gold);
}

.heroCutLineBody {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(14px, 1.65vw, 17px);
    font-weight: 400;
    line-height: 1.55;
    color: var(--text);
    text-transform: none;
    letter-spacing: 0;
    padding-top: 0.4em;
}

.heroCutLineCities {
    font-size: 13px;
    opacity: 0.7;
    padding-top: 0.55em;
}

.heroCycler {
    margin: 12px 0 20px;
    max-width: 540px;
}

.heroHouseCol {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 620px;
    min-width: 0;
    z-index: 2;
    align-self: start;
    justify-self: center;
    transform: translateX(-8px);
}

.heroFormCol {
    display: flex;
    width: 100%;
    max-width: 456px;
    min-width: 0;
    z-index: 2;
    align-self: start;
    justify-self: start;
}

.heroFormCol .heroFormPanel {
    margin-top: 0;
    max-width: none;
}

.heroDesc {
    font-size: 16px;
    color: var(--text);
    max-width: 480px;
    margin-bottom: 36px;
    line-height: 1.7;
    word-wrap: break-word;
    overflow-wrap: break-word;
}

.heroActions {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
    width: 100%;
}

.btnPrimary {
    background: var(--gold);
    color: var(--dark);
    padding: 14px 28px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s, transform 0.2s;
    min-height: 48px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 16px 34px rgba(200, 150, 30, 0.22);
}

.btnPrimary::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: -65%;
    width: 42%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.26), transparent);
    transform: skewX(-22deg);
    animation: ctaSheen 7s ease-in-out infinite;
    pointer-events: none;
}

.btnPrimary:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
    color: var(--dark);
}

.btnPrimary:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
}

.btnSecondary {
    color: var(--white);
    padding: 13px 24px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    transition: border-color 0.2s, color 0.2s;
    min-height: 48px;
}

.btnSecondary:hover {
    border-color: var(--gold);
    color: var(--gold);
}

.heroTrust {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.trustItem {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--gray);
    font-weight: 500;
}

.trustItem svg {
    color: var(--gold);
    width: 13px;
    height: 13px;
    flex-shrink: 0;
}

.trustSep {
    color: rgba(255, 255, 255, 0.1);
    font-size: 12px;
}

/* Stats block — bottom right of hero */
.heroStats {
    position: absolute;
    bottom: 30px;
    right: 40px;
    z-index: 10;
    display: flex;
    gap: 34px;
}

@media (max-width: 1130px) {
    .heroInner {
        grid-template-columns: 1fr;
        padding: 60px 30px 60px 30px;
    }

    .heroHouseCol,
    .heroFormCol {
        max-width: 420px;
        justify-self: start;
        transform: none;
    }

    .heroStats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        background-color: rgba(200, 150, 30, 0.1);
        position: static;
        margin-top: 24px;
        width: 100%;
    }

    .heroStats .statBox {
        background-color: var(--dark-mid);
        padding: 16px 12px;
    }
}

@media (max-width: 760px) {
    .hero {
        min-height: auto;
    }

    .heroInner {
        grid-template-columns: minmax(0, 1fr);
        padding: 28px 16px 36px;
        gap: 20px;
    }

    .heroContent,
    .heroHouseCol,
    .heroFormCol {
        width: 100%;
        max-width: none;
        justify-self: stretch;
    }

    .heroFormPanel {
        max-width: none;
        padding: 22px 18px;
    }

    .heroCutLineTitle {
        font-size: clamp(34px, 12vw, 52px);
        line-height: 0.92;
    }

    .heroCutLineBody {
        font-size: 14px;
        line-height: 1.55;
    }

    .heroCutLineCities {
        font-size: 12px;
    }

    .heroCycler {
        margin: 8px 0 18px;
    }

    .heroActions {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
    }

    .btnPrimary,
    .btnSecondary {
        width: 100%;
        justify-content: center;
        min-height: 56px;
    }

    .heroReviewBlock {
        align-items: center;
        text-align: center;
    }

    .heroDesc {
        white-space: normal;
    }

    .heroReviewRow {
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .heroReviewLabel {
        text-align: center;
        width: 100%;
    }

    .heroReviewItems {
        flex-direction: row;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 0;
        width: 100%;
    }

    .heroReviewIcon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: auto;
        height: auto;
        padding: 0;
        min-width: 40px;
    }

    .heroReviewIcon img,
    .heroReviewIcon svg {
        width: auto;
        height: 28px;
        max-width: 120px;
    }

    .heroTrust {
        gap: 10px 14px;
        padding-top: 20px;
    }
}

.statBox {
    text-align: center;
    background-color: transparent;
    padding: 18px 14px;
    color: #f5f3ef;
    font-size: 16px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.statNum {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 42px;
    font-weight: 800;
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.02em;
}

.statLabel {
    font-size: 11px;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 4px;
    word-break: break-word;
    overflow-wrap: break-word;
    line-height: 1.3;
}

/* ─── HERO CALL LINK (mobile only) ──────────────── */
.heroCallLink {
    display: none;
    align-items: center;
    gap: 8px;
    color: var(--gold);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    margin-top: 4px;
}

.heroCallLink svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
}

@media (max-width: 768px) {
    .heroCallLink {
        display: flex;
    }
}

/* ─── HERO REVIEW COUNT ───────────────────────────── */
.heroReviewCount {
    font-size: 13px;
    color: var(--gray);
    font-weight: 500;
    letter-spacing: 0.02em;
    align-self: center;
}

/* ─── FORM PROMISE ────────────────────────────────── */
.formPromise {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #4caf50;
    margin-bottom: 10px;
}

.formPromise svg {
    flex-shrink: 0;
    stroke: #4caf50;
}

/* ─── MOBILE STICKY CTA BAR ───────────────────────── */
.mobileStickyBar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 500;
    height: 56px;
    background: var(--dark);
    border-top: 1px solid rgba(200, 150, 30, 0.2);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.4);
}

.mobileStickyCall {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 50%;
    height: 100%;
    color: var(--gold);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-right: 1px solid rgba(200, 150, 30, 0.15);
    transition: background 0.2s;
}

.mobileStickyCall:hover {
    background: rgba(200, 150, 30, 0.08);
}

.mobileStickyCall svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
}

.mobileStickyQuote {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50%;
    height: 100%;
    background: var(--gold);
    color: var(--dark);
    border: none;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
}

.mobileStickyQuote:hover {
    background: var(--gold-light);
}

@media (max-width: 768px) {
    .mobileStickyBar {
        display: flex;
    }
}

/* ─── HERO CREDENTIALS STRIP ─────────────────────── */
.heroCredentials {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px 20px;
    padding: 10px 24px;
    background: rgba(0,0,0,0.25);
    border-top: 1px solid rgba(200,150,30,0.12);
    font-size: 11px;
    font-weight: 600;
    color: var(--gray);
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.heroCredentials span {
    display: flex;
    align-items: center;
    gap: 5px;
}

/* ─── SECTION SHARED ─────────────────────────────── */
.sectionHeader {
    margin-bottom: 44px;
}

.sectionLabel {
    font-size: 12px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
}

.sectionLabel::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--gold);
    flex-shrink: 0;
    transform-origin: left center;
    animation: goldLineGrow 0.5s ease-out both;
}

.trustBand {
    position: relative;
    z-index: 5;
    margin-top: -1px;
    padding: 0 20px 28px;
    background: linear-gradient(180deg, rgba(15, 25, 35, 0.98) 0%, rgba(15, 25, 35, 0.92) 100%);
}

.trustBandInner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2px;
    border: 1px solid rgba(200, 150, 30, 0.12);
    background: rgba(200, 150, 30, 0.08);
    border-radius: 4px;
    overflow: hidden;
}

.trustBandCard {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    min-width: 0;
    padding: 22px 20px;
    background: rgba(11, 19, 28, 0.95);
}

.trustBandIcon {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: rgba(200, 150, 30, 0.12);
    color: var(--gold);
}

.trustBandIcon svg {
    width: 16px;
    height: 16px;
}

.trustBandCopy {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
}

.trustBandValue {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 30px;
    line-height: 0.95;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
}

.trustBandLabel {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
}

.trustBandMeta {
    font-size: 13px;
    line-height: 1.45;
    color: var(--gray);
}

.mobileChipNav,
.mobileSectionToggle {
    display: none;
}

.mobileSectionBlock {
    display: block;
}

.mobileSectionPanel {
    display: block;
}

@media (max-width: 768px) {
    .trustBand {
        padding: 0 16px 20px;
    }

    .trustBandInner {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .trustBandCard {
        padding: 18px 16px;
    }

    .trustBandValue {
        font-size: 24px;
    }

    .mobileChipNav {
        display: block;
        padding: 0 16px 16px;
        background: var(--dark);
    }

    .mobileChipNavInner {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
    }

    .mobileChipNavInner::-webkit-scrollbar {
        display: none;
    }

    .mobileChip {
        flex: 0 0 auto;
        min-height: 40px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(200, 150, 30, 0.18);
        background: rgba(11, 19, 28, 0.96);
        color: var(--text);
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .mobileChipActive {
        background: var(--gold);
        color: var(--dark);
        border-color: var(--gold);
    }

    .mobileSectionBlock {
        border-top: 1px solid rgba(200, 150, 30, 0.08);
        background: var(--dark);
    }

    .mobileSectionToggle {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 20px;
        border: none;
        background: transparent;
        color: var(--white);
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .mobileSectionToggleIcon {
        color: var(--gold);
        font-size: 20px;
        line-height: 1;
        flex-shrink: 0;
    }

    .mobileSectionPanel {
        display: none;
    }

    .mobileSectionBlockOpen .mobileSectionPanel {
        display: block;
    }

    .sectionLabel {
        font-size: 12px;
        gap: 12px;
        overflow-wrap: anywhere;
    }

    .servicesSection {
        padding: 76px 16px;
    }

    .servicesInner {
        gap: 32px;
    }

    .hwwStepsCompact {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .bottomCtaActions {
        flex-direction: column;
        align-items: stretch;
    }

    .bottomCtaActions .btnPrimary,
    .bottomCtaActions .btnSecondary {
        width: 100%;
        justify-content: center;
    }

    .bottomCtaTrust {
        gap: 8px 12px;
        font-size: 11px;
    }
}

.sectionTitle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--white);
}

.sectionTitle em {
    font-style: normal;
    color: var(--gold);
}

/* ─── SERVICES PREVIEW ───────────────────────────── */
.servicesSection {
    padding: 96px 40px;
    background: var(--dark);
}

.servicesInner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 60px;
    align-items: start;
}

/* Sticky left label column */
.servicesLeft {
    position: sticky;
    top: 100px;
    align-self: start;
    padding-top: 4px;
}

.servicesLeftDesc {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.7;
    margin-top: 16px;
    max-width: 220px;
}

.servicesRight {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.servicesGrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2px;
    background: rgba(200, 150, 30, 0.06);
    border: 1px solid rgba(200, 150, 30, 0.08);
    border-radius: 4px;
    overflow: hidden;
}

.serviceCard {
    background: #0e1622;
    padding: 28px 24px;
    cursor: pointer;
    transition: background 0.25s, border-color 0.25s;
    position: relative;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border: 1px solid #1a2535;
    min-width: 0;
}

/* Top-left corner bracket */
.serviceCard::before {
    content: '';
    position: absolute;
    top: 10px; left: 10px;
    width: 14px; height: 14px;
    border-top: 2px solid var(--gold);
    border-left: 2px solid var(--gold);
    transition: width 0.2s, height 0.2s;
}

/* Bottom-right corner bracket */
.serviceCard::after {
    content: '';
    position: absolute;
    bottom: 10px; right: 10px;
    width: 14px; height: 14px;
    border-bottom: 2px solid var(--gold);
    border-right: 2px solid var(--gold);
    transition: width 0.2s, height 0.2s;
}

.serviceCard:hover { background: #131e30; border-color: #253548; }
.serviceCard:hover::before,
