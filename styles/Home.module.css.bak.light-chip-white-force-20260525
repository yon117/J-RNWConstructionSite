/* ═══════════════════════════════════════════════════════
   HORIZ ROW — side-by-side section pairs (OpenAI/Verge style)
═══════════════════════════════════════════════════════ */
.horizRow {
  display: grid;
  grid-template-columns: 3fr 2fr;
  border-top: 1px solid rgba(200, 150, 30, 0.08);
  align-items: start;
  /* Right-column background fills any gap below the sticky card */
  background: var(--dark);
}

/* Strip any top borders / top margins from direct children */
.horizRow > * {
  border-top: none !important;
  margin-top: 0 !important;
}

/* Left column: sticky (taller right content scrolls past it) */
.horizRow > *:first-child {
  position: sticky;
  top: 88px;
  align-self: start;
}

/* Right column: normal scroll + divider */
.horizRow > *:not(:first-child) {
  border-left: 1px solid rgba(255, 255, 255, 0.05);
}

/* Flip variant: right column sticks, left scrolls (when left is taller) */
.horizRowFlip > *:first-child {
  position: static;
  align-self: auto;
}
.horizRowFlip > *:not(:first-child) {
  position: sticky;
  top: 88px;
  align-self: start;
  border-left: 1px solid rgba(255, 255, 255, 0.05);
}

/* ── Services adapts to the narrow right column ── */
.horizRow .servicesSection {
  padding: 52px 32px;
  background: var(--dark);
}
.horizRow .servicesSection .servicesInner {
  grid-template-columns: 1fr;
  gap: 24px;
  max-width: none;
}
.horizRow .servicesSection .servicesLeft {
  position: static;
  padding-top: 0;
}
.horizRow .servicesSection .servicesLeftDesc {
  max-width: none;
}
.horizRow .servicesSection .servicesRight {
  gap: 0;
}
.horizRow .servicesSection .servicesGrid {
  grid-template-columns: 1fr 1fr;
}

