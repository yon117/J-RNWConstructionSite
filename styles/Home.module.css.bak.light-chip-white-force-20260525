  .splitRow,
  .splitRowAlt { grid-template-columns: 1fr; }
  .splitRow > section:last-child,
  .splitRow > div:last-child { border-left: none; border-top: 1px solid rgba(255,255,255,0.05); }
  .splitRow .projectsGrid { grid-template-columns: 1fr 1fr; grid-template-rows: 220px 220px; }
