/* ── Responsive collapse ── */
@media (max-width: 1100px) {
  .horizRow {
    grid-template-columns: 1fr;
  }
  .horizRow > *:not(:first-child) {
    border-left: none;
    border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
  }
  .horizRow .servicesSection .servicesGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .photoBentoCard {
    min-height: 400px;
  }

  /* Kill sticky on mobile — columns stack, sticky causes empty gaps */
  .horizRow > *:first-child,
  .horizRowFlip > *:not(:first-child) {
    position: static !important;
    align-self: auto;
    top: auto;
  }
}

@media (max-width: 768px) {
  .mobileServicesOrder {
    order: 1;
  }
  .mobileProcessOrder {
    order: 2;
  }
  .horizRow .servicesSection {
    padding: 44px 16px;
  }
  .horizRow .servicesSection .servicesGrid {
    grid-template-columns: 1fr;
  }
  .photoBentoCard {
    min-height: 340px;
  }
  .photoBentoOverlay {
    padding: 28px 24px;
  }
  .photoBentoStatsGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .splitRow .areasMap iframe {
    height: 220px;
  }
}

@keyframes ctaSheen {
  0%, 72%, 100% { transform: translateX(0) skewX(-22deg); opacity: 0; }
  78% { opacity: 0.9; }
  88% { transform: translateX(300%) skewX(-22deg); opacity: 0; }
}

@keyframes goldLineGrow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

