/* ─── PROJECTS PREVIEW ───────────────────────────── */
.projectsSection {
    padding: 96px 40px;
    background: var(--dark-mid);
}

.projectsInner {
    max-width: 1200px;
    margin: 0 auto;
}

.projectsHeader {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 44px;
}

.projectsGrid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 280px 280px;
    gap: 3px;
    border-radius: 4px;
    overflow: hidden;
}

.projectCard {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: var(--dark-card);
    min-height: 260px;
}

.projectCard.featured {
    grid-row: span 2;
    min-height: 563px;
}

.projectPhoto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, filter 0.3s;
    filter: brightness(0.65) saturate(0.8);
}

.projectCard:hover .projectPhoto {
    transform: scale(1.05);
    filter: brightness(0.8) saturate(1);
}

.projectOverlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 18, 28, 0.95) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 6px;
    padding: 18px 18px 20px;
}

.projectCategory {
    font-size: 9px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0;
}

.projectMeta {
    font-size: 11px;
    color: var(--gray);
    font-weight: 500;
    margin-top: 0;
    letter-spacing: 0.02em;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.projectMeta:empty {
    display: none;
}

.projectTitle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.08;
    color: var(--white);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.projectCard.featured .projectTitle {
    font-size: 26px;
    -webkit-line-clamp: 3;
}

.projectCard:not(.featured) .projectMeta {
    display: none;
}

.photoBadge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(8, 18, 28, 0.85);
    border: 1px solid rgba(200, 150, 30, 0.3);
    border-radius: 2px;
    padding: 3px 9px;
    font-size: 10px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.08em;
    backdrop-filter: blur(4px);
}

/* ─── ABOUT SECTION ──────────────────────────────── */
.aboutSection {
    padding: 96px 40px;
    background: var(--dark-mid);
    border-top: 1px solid rgba(200,150,30,0.1);
}

.aboutInner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
}

.aboutLogoWrap {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
}

.aboutLogoWrap img {
    border-radius: 50%;
    opacity: 0.92;
}

.aboutContent h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 20px;
    color: var(--white);
}

.aboutContent h2 em {
    font-style: normal;
    color: var(--gold);
}

.aboutContent p {
    font-size: 15px;
    color: var(--text);
    line-height: 1.85;
    border-left: 2px solid rgba(200,150,30,0.25);
    padding-left: 20px;
    margin-top: 20px;
}

/* ─── CONTACT SECTION ────────────────────────────── */
.contactSection {
    padding: 96px 40px;
    background: var(--dark-mid);
}

.contactInner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
}

.contactInfo h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(32px, 3vw, 48px);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 16px;
    color: var(--white);
}

.contactInfo h2 em {
    font-style: normal;
    color: var(--gold);
}

.contactInfo p {
    font-size: 15px;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 32px;
}

.contactDetail {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.contactDetail:first-of-type {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.contactIcon {
    width: 36px;
    height: 36px;
    background: rgba(200, 150, 30, 0.1);
    border: 1px solid rgba(200, 150, 30, 0.2);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
}

.contactIcon svg {
    width: 15px;
    height: 15px;
}

.contactDetailText {
    font-size: 14px;
    color: var(--text);
}

.contactDetailText strong {
    display: block;
    font-size: 10px;
    font-weight: 600;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 2px;
}

/* Contact form box */
.contactForm {
    background: var(--dark-card);
    border: 1px solid rgba(200, 150, 30, 0.12);
    border-radius: 4px;
    padding: 36px 32px;
}

.formTitle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 24px;
    letter-spacing: 0.04em;
    color: var(--white);
}

.formRow {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.formGroup {
    margin-bottom: 14px;
}

.formGroup label {
    display: block;
    font-size: 10px;
    font-weight: 600;
    color: var(--gray);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
}

.formGroup input,
.formGroup select,
.formGroup textarea {
    width: 100%;
    background: var(--dark-mid);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    padding: 12px 14px;
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    font-size: 14px;
    outline: none;
    appearance: none;
    min-height: 48px;
    transition: border-color 0.2s;
}

.formGroup input:focus,
.formGroup select:focus,
.formGroup textarea:focus {
    border-color: var(--gold);
}

.formGroup input::placeholder,
.formGroup textarea::placeholder {
    color: var(--gray);
}

.formGroup select option {
    background: var(--dark-mid);
    color: var(--white);
}

.formGroup textarea {
    min-height: 100px;
    resize: vertical;
}

.formSubmit {
    width: 100%;
    background: var(--gold);
    color: var(--dark);
    padding: 14px;
    border-radius: 3px;
    border: none;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    min-height: 52px;
    margin-top: 6px;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.formSubmit:hover {
    background: var(--gold-light);
}

.formSubmit:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
}

.formSubmit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.formNote {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--gray);
    margin-top: 10px;
}

.formNote svg {
    color: var(--gold);
    width: 12px;
    height: 12px;
    flex-shrink: 0;
}

.formSuccess {
    color: #4caf50;
    text-align: center;
    font-size: 13px;
    margin-top: 8px;
}

.formError {
    color: #f44336;
    text-align: center;
    font-size: 13px;
    margin-top: 8px;
}

.validationError {
    color: #ff4444;
    font-size: 11px;
    margin-top: 4px;
}

/* ─── FLOATING BUTTON ────────────────────────────── */
.floatingContactBtn {
    position: fixed;
    bottom: 28px;
    left: 28px;
    background: var(--gold);
    color: var(--dark);
    border: none;
    border-radius: 50px;
    padding: 14px 24px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(200, 150, 30, 0.4);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    z-index: 999;
    font-family: 'Barlow Condensed', sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.floatingContactBtn:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
}

.floatingBtnIcon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
}

.floatingBtnText {
    white-space: nowrap;
}

