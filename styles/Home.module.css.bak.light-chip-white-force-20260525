    cursor: pointer;
    font-size: 1rem;
    font-weight: 700;
    padding: 2px 6px;
    opacity: 0.7;
    flex-shrink: 0;
}
.announcementClose:hover { opacity: 1; }

/* ── SERVICE CARD FEATURED ── */
.serviceCardFeatured {
    border: 2px solid var(--gold) !important;
    position: relative;
}
.popularBadge {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: #111;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: 20px;
    white-space: nowrap;
}

/* ── WARNING SIGNS SECTION ── */
.warningSection { padding: 5rem 1.5rem; background: #0d0d0d; border-top: 1px solid #1e1e1e; }
.warningInner { max-width: 720px; margin: 0 auto; }
.warningSubtitle { color: #888; font-size: 0.95rem; margin-top: 0.6rem; line-height: 1.6; }

@keyframes warnFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* Featured card */
.warnFeatCard {
    background: #111;
    border: 1px solid #242424;
    border-radius: 12px;
    padding: 2rem;
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: warnFadeIn 0.5s ease;
}
.warnDivider { height: 1px; background: #222; margin: 0.25rem 0; }

/* Severity */
.warnFeatSev {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
}
.sev_critical { color: #e74c3c; }
.sev_high     { color: #e67e22; }
.sev_medium   { color: var(--gold); }
.warnFeatDot {
    width: 8px; height: 8px; border-radius: 50%;
    background: currentColor;
    animation: pulse 1.4s infinite;
}

/* Title area */
.warnFeatService {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: -0.5rem;
}
.warnFeatTitle {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0;
}
.warnFeatDesc { color: #888; font-size: 0.88rem; line-height: 1.65; margin: 0; }

/* Progression */
.warnProgLabel {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #555;
}
.warnProgression {
    display: flex;
    align-items: flex-start;
    gap: 0;
    width: 100%;
}
.warnProgStep {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex: 0 0 auto;
    max-width: 90px;
}
.warnProgNum {
    width: 34px; height: 34px;
    border-radius: 50%;
    border: 2px solid;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.85rem;
    background: transparent;
    flex-shrink: 0;
}
.warnProgLine {
    flex: 1; height: 2px;
    align-self: flex-start;
    margin-top: 16px;
    min-width: 20px;
}
.warnProgStepLabel {
    font-size: 0.68rem; color: #888;
    text-align: center; line-height: 1.3;
}

/* Risk + Fix */
.warnRiskFix {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
}
.warnRFLabel {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: 0.4rem;
}
.warnRiskFix > div:first-child p { color: #c07070; font-size: 0.83rem; line-height: 1.6; margin: 0; }
.warnRiskFix > div:last-child  p { color: #70a870; font-size: 0.83rem; line-height: 1.6; margin: 0; }

/* Bottom CTA */
.warnFeatBottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.warnCtaText {
    background: none; border: none; cursor: pointer;
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.12em;
    color: #888;
    transition: color 0.2s;
}
.warnCtaText:hover { color: var(--gold); }
.warnCtaBtn {
    background: none;
    border: 1px solid #333;
    color: var(--gold);
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em;
    padding: 8px 18px; border-radius: 4px; cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
}
.warnCtaBtn:hover { background: var(--gold); color: #111; border-color: var(--gold); }

/* Dots */
.warnPagination { display: flex; justify-content: center; gap: 6px; margin-top: 1.75rem; flex-wrap: wrap; }
.warnDot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #2a2a2a; border: none; cursor: pointer;
    transition: background 0.2s, transform 0.15s;
}
.warnDotActive { background: var(--gold); transform: scale(1.4); }

@media (max-width: 600px) {
    .warnFeatTitle { font-size: 1.1rem; }
    .warnRiskFix { grid-template-columns: 1fr; gap: 1rem; }
    .warnProgression { gap: 0; }
    .warnProgStep { max-width: 65px; }
    .warnProgStepLabel { font-size: 0.6rem; }
    .warnFeatBottom {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }
}

/* ── HANDLE EVERYTHING SECTION ── */
