.reviewsSection {
    position: relative;
    overflow: hidden;
    padding: 88px 20px 96px;
    background:
        linear-gradient(180deg, rgba(247, 243, 236, 0.98) 0%, rgba(243, 236, 226, 0.96) 58%, rgba(239, 231, 220, 0.82) 100%),
        radial-gradient(circle at top, rgba(212, 175, 55, 0.1), transparent 38%);
}

.reviewsSection::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 160px;
    background: linear-gradient(180deg, rgba(239, 231, 220, 0) 0%, rgba(239, 231, 220, 0.95) 100%);
    pointer-events: none;
}

.container {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    margin: 0 auto;
}

.header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: 42px;
    text-align: center;
}

.header h2 {
    margin: 0;
    color: #101723;
    font-size: clamp(2.2rem, 4vw, 3.7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.96;
}

.header p {
    margin: 0;
    max-width: 520px;
    color: rgba(16, 23, 35, 0.66);
    font-size: 1rem;
    line-height: 1.7;
}

.marqueeStack {
    display: flex;
    flex-direction: column;
    gap: 22px;
}

.marqueeViewport {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
}

.marqueeTrack {
    display: flex;
    width: max-content;
    gap: 22px;
}

.isPaused .marqueeTrack,
.marqueeViewport:hover .marqueeTrack {
    animation-play-state: paused;
}

.marqueeTrackTop {
    animation: marquee-right 42s linear infinite;
}

.marqueeTrackBottom {
    animation: marquee-left 34s linear infinite;
}

.reviewCard {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    width: min(332px, 82vw);
    min-height: 212px;
    padding: 22px;
    border: 1px solid rgba(16, 23, 35, 0.08);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 40px rgba(26, 37, 47, 0.06);
    backdrop-filter: blur(10px);
    text-align: left;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.reviewCard:hover {
    transform: translateY(-3px);
    border-color: rgba(16, 23, 35, 0.14);
    box-shadow: 0 20px 42px rgba(26, 37, 47, 0.1);
}

.reviewCard:focus-visible {
    outline: 2px solid rgba(212, 175, 55, 0.8);
    outline-offset: 3px;
}

.reviewCardTop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.reviewQuoteWrap {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.quoteMark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 12px;
    background: rgba(212, 175, 55, 0.12);
    color: #b78712;
    font-size: 1.3rem;
    line-height: 1;
    font-weight: 700;
}

.stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
    color: #d4af37;
    font-size: 0.82rem;
}

.starFilled {
    color: #d4af37;
}

.starEmpty {
    color: rgba(212, 175, 55, 0.28);
}

.reviewText {
    margin: 0;
    color: #111927;
    font-size: 0.96rem;
    line-height: 1.62;
    overflow-wrap: anywhere;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.reviewMeta {
    display: flex;
    align-items: center;
    gap: 14px;
}

.avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: linear-gradient(135deg, #d4af37 0%, #f0cb58 100%);
    color: #101723;
    font-size: 0.92rem;
    font-weight: 700;
    flex-shrink: 0;
}

.platformBadge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 5px 9px;
    border-radius: 999px;
    font-size: 0.69rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
}

.platformBadge.google {
    background: rgba(66, 133, 244, 0.12);
    color: #2460d8;
    border: 1px solid rgba(66, 133, 244, 0.2);
}

.platformBadge.yelp {
    background: rgba(211, 35, 35, 0.09);
    color: #c42121;
    border: 1px solid rgba(211, 35, 35, 0.18);
}

.reviewerInfo {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
}

.reviewerInfo h4 {
    margin: 0;
    color: #101723;
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.2;
}

.designation {
    margin: 0;
    color: rgba(16, 23, 35, 0.58);
    font-size: 0.82rem;
    line-height: 1.4;
    text-transform: none;
}

.reviewOverlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(8, 12, 18, 0.58);
    backdrop-filter: blur(8px);
}

.reviewModal {
    display: flex;
    flex-direction: column;
    gap: 22px;
    width: min(680px, calc(100vw - 32px));
    max-height: min(78vh, 760px);
    padding: 28px;
    overflow: auto;
    border-radius: 28px;
    border: 1px solid rgba(16, 23, 35, 0.08);
    background: rgba(255, 252, 247, 0.98);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.24);
}

.reviewModalTop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
}

.closeButton {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(16, 23, 35, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    color: #101723;
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
}

.closeButton:hover {
    background: #ffffff;
}

.reviewTextFull {
    display: block;
    overflow: visible;
    font-size: 1rem;
    line-height: 1.78;
}

:global([data-theme="dark"]) .reviewsSection {
    background:
        linear-gradient(180deg, #0d1c2f 0%, #10243b 54%, #132a45 100%),
        radial-gradient(circle at top, rgba(82, 125, 193, 0.18), transparent 40%);
}

:global([data-theme="dark"]) .reviewsSection::after {
    background: linear-gradient(180deg, rgba(19, 42, 69, 0) 0%, rgba(13, 28, 47, 0.96) 100%);
}

:global([data-theme="dark"]) .header h2 {
    color: #f7f9fc;
}

:global([data-theme="dark"]) .header p {
    color: rgba(247, 249, 252, 0.62);
}

:global([data-theme="dark"]) .reviewCard {
    background: rgba(17, 30, 48, 0.9);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
}

:global([data-theme="dark"]) .reviewText,
:global([data-theme="dark"]) .reviewerInfo h4 {
    color: #f7f9fc;
}

:global([data-theme="dark"]) .designation {
    color: rgba(247, 249, 252, 0.58);
}

:global([data-theme="dark"]) .platformBadge.google {
    background: rgba(123, 156, 255, 0.14);
    color: #8faafc;
    border-color: rgba(123, 156, 255, 0.24);
}

:global([data-theme="dark"]) .platformBadge.yelp {
    background: rgba(255, 128, 111, 0.12);
    color: #ff9d8f;
    border-color: rgba(255, 128, 111, 0.22);
}

:global([data-theme="dark"]) .quoteMark {
    background: rgba(212, 175, 55, 0.16);
    color: #f0cb58;
}

:global([data-theme="dark"]) .starFilled {
    color: #f0cb58;
}

:global([data-theme="dark"]) .starEmpty {
    color: rgba(240, 203, 88, 0.24);
}

@keyframes marquee-left {
    from {
        transform: translate3d(0, 0, 0);
    }

    to {
        transform: translate3d(calc(-50% - 11px), 0, 0);
    }
}

@keyframes marquee-right {
    from {
        transform: translate3d(calc(-50% - 11px), 0, 0);
    }

    to {
        transform: translate3d(0, 0, 0);
    }
}

@media (max-width: 900px) {
    .reviewsSection {
        padding: 72px 16px 84px;
    }

    .reviewCard {
        width: min(300px, 86vw);
        min-height: 204px;
        padding: 20px;
    }

    .marqueeTrackTop {
        animation-duration: 36s;
    }

    .marqueeTrackBottom {
        animation-duration: 30s;
    }
}

@media (max-width: 640px) {
    .reviewsSection {
        padding: 64px 12px 78px;
    }

    .header {
        margin-bottom: 32px;
    }

    .header p {
        font-size: 0.95rem;
    }

    .marqueeStack {
        gap: 16px;
    }

    .marqueeViewport {
        mask-image: none;
        -webkit-mask-image: none;
    }

    .reviewCard {
        width: min(274px, 88vw);
        min-height: 196px;
        padding: 18px;
        border-radius: 24px;
    }

    .reviewText {
        font-size: 0.92rem;
        line-height: 1.58;
    }

    .quoteMark {
        width: 32px;
        height: 32px;
        border-radius: 12px;
    }

    .reviewModal {
        width: min(100vw - 20px, 560px);
        max-height: 82vh;
        padding: 20px;
        border-radius: 24px;
    }
}
