.wrap {
  display: flex;
  flex-direction: column;
  gap: 16px;
  align-items: flex-start;
}

.modeBtns {
  display: inline-flex;
  gap: 4px;
  width: fit-content;
  padding: 4px;
  border-radius: 22px;
  background: rgba(11, 18, 31, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 18px 36px rgba(0, 0, 0, 0.26);
}

.modeBtn {
  padding: 11px 20px;
  border: none;
  border-radius: 18px;
  background: transparent;
  color: rgba(245, 243, 239, 0.72);
  font-family: 'Barlow', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
}

.modeBtn:hover {
  color: #f5f3ef;
}

.modeBtn.active {
  background: linear-gradient(135deg, #d4af37 0%, #f0cb58 100%);
  color: #101723;
}

.sceneWrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 0.86;
  overflow: hidden;
  border-radius: 30px;
  background: linear-gradient(180deg, rgba(252, 249, 242, 0.98) 0%, rgba(235, 240, 247, 0.98) 100%);
  border: 1px solid rgba(12, 22, 35, 0.08);
  box-shadow: 0 30px 64px rgba(0, 0, 0, 0.16);
}

.sceneVisual {
  position: relative;
  width: 100%;
  height: 100%;
}

.sceneImage {
  object-fit: cover;
  object-position: center center;
}

.sceneOverlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(12, 18, 29, 0.08) 100%),
    radial-gradient(circle at 50% 10%, rgba(255, 255, 255, 0.22), transparent 40%);
  z-index: 1;
}

.sceneChip {
  position: absolute;
  top: 12px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  padding: 10px 16px;
  border-radius: 999px;
  background: rgba(35, 39, 49, 0.96);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #f6f3ef;
  font-family: 'Barlow', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
}

.sceneSvg {
  display: block;
  width: 100%;
  height: 100%;
}

.houseDrawing {
  filter: drop-shadow(0 18px 34px rgba(32, 52, 79, 0.12));
}

.sidingLine {
  stroke: rgba(124, 136, 156, 0.34);
  stroke-width: 3;
  stroke-linecap: round;
}

.windowMuntin {
  stroke: #8b99ad;
  stroke-width: 4;
  stroke-linecap: round;
}

.floorBoard {
  stroke: rgba(120, 83, 38, 0.16);
  stroke-width: 4;
}

.trimStroke {
  stroke: rgba(170, 160, 142, 0.8);
  stroke-width: 6;
  stroke-linecap: round;
}

.tableVein {
  stroke: rgba(204, 176, 132, 0.4);
  stroke-width: 3;
}

.baseDivider {
  stroke: rgba(170, 147, 112, 0.22);
  stroke-width: 4;
}

.hotspotLayer {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.hotspotBtn {
  position: absolute;
  transform: translate(-50%, -50%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
  z-index: 4;
}

.hotspotBtn:focus-visible {
  outline: none;
}

.hotspotDot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #d4af37;
  border: 3px solid #ffffff;
  box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.22);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hotspotBtn:hover .hotspotDot,
.hotspotBtnActive .hotspotDot {
  transform: scale(1.08);
  box-shadow: 0 0 0 7px rgba(212, 175, 55, 0.16);
}

.hotspotTooltip {
  position: absolute;
  left: calc(100% + 10px);
  top: 50%;
  transform: translateY(-50%) translateX(-6px);
  width: 220px;
  padding: 12px 14px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(17, 26, 39, 0.08);
  color: #f6f3ef;
  font-family: 'Barlow', sans-serif;
  text-align: left;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
  box-shadow: 0 20px 40px rgba(16, 23, 35, 0.18);
}

.hotspotTitle {
  display: block;
  margin-bottom: 6px;
  color: #0f1923;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.hotspotDesc {
  display: block;
  color: rgba(15, 25, 35, 0.72);
  font-size: 13px;
  font-weight: 500;
  line-height: 1.45;
}

.hotspotBtn:hover .hotspotTooltip,
.hotspotBtn:focus-visible .hotspotTooltip,
.hotspotBtnActive .hotspotTooltip {
  opacity: 1;
  transform: translateY(-50%) translateX(0);
}

.hotspotBtnLeft .hotspotTooltip {
  left: auto;
  right: calc(100% + 10px);
  transform: translateY(-50%) translateX(6px);
}

.hotspotBtnLeft:hover .hotspotTooltip,
.hotspotBtnLeft:focus-visible .hotspotTooltip,
.hotspotBtnLeft.hotspotBtnActive .hotspotTooltip {
  transform: translateY(-50%) translateX(0);
}

.modeLabel {
  position: absolute;
  right: 18px;
  bottom: 14px;
  z-index: 3;
  color: rgba(17, 26, 39, 0.48);
  font-family: 'Barlow', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

@media (max-width: 768px) {
  .sceneWrap {
    aspect-ratio: 1 / 0.96;
    border-radius: 24px;
  }

  .modeBtn {
    padding: 9px 16px;
    font-size: 11px;
  }

  .hotspotBtn {
    width: 48px;
    height: 48px;
  }

  .hotspotTooltip {
    left: 50%;
    top: calc(100% + 12px);
    transform: translateX(-50%) translateY(-4px);
    width: min(220px, calc(100vw - 72px));
  }

  .hotspotBtn:hover .hotspotTooltip,
  .hotspotBtn:focus-visible .hotspotTooltip,
  .hotspotBtnActive .hotspotTooltip {
    transform: translateX(-50%) translateY(0);
  }

  .hotspotBtnLeft .hotspotTooltip {
    right: auto;
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
  }

  .hotspotBtnLeft:hover .hotspotTooltip,
  .hotspotBtnLeft:focus-visible .hotspotTooltip,
  .hotspotBtnLeft.hotspotBtnActive .hotspotTooltip {
    transform: translateX(-50%) translateY(0);
  }

  .sceneChip {
    top: 10px;
    padding: 9px 14px;
    font-size: 10px;
  }

  .modeLabel {
    right: 14px;
    bottom: 12px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .modeBtn,
  .hotspotDot,
  .hotspotLabel,
  .detailLink {
    transition: none;
  }
}
