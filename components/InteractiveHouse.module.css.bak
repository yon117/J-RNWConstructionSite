.wrap {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.modeBtns {
  display: inline-flex;
  gap: 4px;
  width: fit-content;
  padding: 4px;
  border-radius: 18px;
  background: rgba(10, 18, 31, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 18px 36px rgba(0, 0, 0, 0.24);
}

.modeBtn {
  padding: 10px 20px;
  border: none;
  border-radius: 14px;
  background: transparent;
  color: rgba(245, 243, 239, 0.72);
  font-family: 'Barlow', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
}

.modeBtn:hover {
  color: #f5f3ef;
}

.modeBtn.active {
  background: linear-gradient(135deg, #d4af37 0%, #f0cb58 100%);
  color: #101723;
}

.sceneWrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 0.78;
  overflow: hidden;
  border-radius: 30px;
  background: rgba(247, 244, 236, 0.98);
  border: 1px solid rgba(12, 22, 35, 0.08);
  box-shadow: 0 30px 64px rgba(0, 0, 0, 0.16);
}

.sceneSvg {
  display: block;
  width: 100%;
  height: 100%;
}

.houseDrawing {
  filter: drop-shadow(0 18px 34px rgba(32, 52, 79, 0.12));
}

.sidingLine {
  stroke: rgba(124, 136, 156, 0.34);
  stroke-width: 3;
  stroke-linecap: round;
}

.windowMuntin {
  stroke: #8b99ad;
  stroke-width: 4;
  stroke-linecap: round;
}

.floorBoard {
  stroke: rgba(120, 83, 38, 0.16);
  stroke-width: 4;
}

.trimStroke {
  stroke: rgba(170, 160, 142, 0.8);
  stroke-width: 6;
  stroke-linecap: round;
}

.tableVein {
  stroke: rgba(204, 176, 132, 0.4);
  stroke-width: 3;
}

.baseDivider {
  stroke: rgba(170, 147, 112, 0.22);
  stroke-width: 4;
}

.hotspotLayer {
  position: absolute;
  inset: 0;
}

.hotspotBtn {
  position: absolute;
  transform: translate(-50%, -50%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
}

.hotspotBtn:focus-visible {
  outline: none;
}

.hotspotDot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #d4af37;
  border: 3px solid #ffffff;
  box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.22);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hotspotBtn:hover .hotspotDot,
.hotspotBtnActive .hotspotDot {
  transform: scale(1.08);
  box-shadow: 0 0 0 7px rgba(212, 175, 55, 0.16);
}

.hotspotLabel {
  position: absolute;
  bottom: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%) translateY(4px);
  padding: 7px 11px;
  border-radius: 999px;
  background: rgba(10, 18, 29, 0.9);
  border: 1px solid rgba(212, 175, 55, 0.28);
  color: #f6f3ef;
  font-family: 'Barlow', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.hotspotBtn:hover .hotspotLabel,
.hotspotBtn:focus-visible .hotspotLabel,
.hotspotBtnActive .hotspotLabel {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.modeLabel {
  position: absolute;
  right: 18px;
  bottom: 14px;
  color: rgba(17, 26, 39, 0.48);
  font-family: 'Barlow', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.detailPanel {
  padding: 18px 18px 16px;
  border-radius: 22px;
  background: rgba(12, 22, 35, 0.86);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 22px 46px rgba(0, 0, 0, 0.24);
}

.detailEyebrow {
  margin-bottom: 8px;
  color: rgba(212, 175, 55, 0.88);
  font-family: 'Barlow', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.detailRow {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
}

.detailTitle {
  margin: 0 0 6px;
  color: #f6f3ef;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 30px;
  line-height: 0.96;
  letter-spacing: -0.03em;
}

.detailText {
  margin: 0;
  max-width: 440px;
  color: rgba(246, 243, 239, 0.78);
  font-family: 'Barlow', sans-serif;
  font-size: 14px;
  line-height: 1.6;
}

.detailLink {
  flex-shrink: 0;
  padding: 12px 16px;
  border-radius: 14px;
  background: linear-gradient(135deg, #d4af37 0%, #f0cb58 100%);
  color: #101723;
  font-family: 'Barlow', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
}

@media (max-width: 768px) {
  .sceneWrap {
    aspect-ratio: 1 / 0.94;
    border-radius: 24px;
  }

  .modeBtn {
    padding: 9px 16px;
    font-size: 11px;
  }

  .detailRow {
    flex-direction: column;
    align-items: flex-start;
  }

  .detailTitle {
    font-size: 24px;
  }

  .detailText {
    font-size: 13px;
  }

  .detailLink {
    width: 100%;
    text-align: center;
  }

  .hotspotLabel {
    font-size: 9px;
  }

  .hotspotBtn {
    width: 48px;
    height: 48px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .modeBtn,
  .hotspotDot,
  .hotspotLabel,
  .detailLink {
    transition: none;
  }
}
