      </defs>

      <g data-piece>
        <rect x="0" y="0" width="900" height="620" rx="34" fill="url(#ext-bg)" />
        <ellipse cx="454" cy="122" rx="250" ry="110" fill="url(#ext-glow)" opacity="0.7" />
      </g>

      <g data-piece className={styles.landscapeGroup}>
        <ellipse cx="470" cy="520" rx="320" ry="46" className={styles.groundGlow} />
        <path
