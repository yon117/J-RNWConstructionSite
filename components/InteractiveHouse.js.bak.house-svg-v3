function SplitPolygon({ splitId, points, leftFill, rightFill, className }) {
  return (
    <>
      <g clipPath={`url(#${splitId}-left)`}>
        <polygon points={points} fill={leftFill} className={className} />
      </g>
      <g clipPath={`url(#${splitId}-right)`}>
        <polygon points={points} fill={rightFill} className={className} />
      </g>
    </>
  );
}

function SplitRect({ splitId, x, y, width, height, rx = 0, leftFill, rightFill, className }) {
  return (
    <>
      <g clipPath={`url(#${splitId}-left)`}>
        <rect x={x} y={y} width={width} height={height} rx={rx} fill={leftFill} className={className} />
      </g>
      <g clipPath={`url(#${splitId}-right)`}>
        <rect x={x} y={y} width={width} height={height} rx={rx} fill={rightFill} className={className} />
      </g>
    </>
  );
}

function HotspotButton({ item, active, onActivate }) {
  return (
    <button
      type="button"
      className={`${styles.hotspotBtn} ${active ? styles.hotspotBtnActive : ''}`}
      style={{ left: item.x, top: item.y }}
      onMouseEnter={() => onActivate(item.id)}
      onFocus={() => onActivate(item.id)}
      onClick={() => onActivate(item.id)}
      aria-label={item.label}
      aria-pressed={active}
    >
      <span className={styles.hotspotPulse} aria-hidden="true" />
      <span className={styles.hotspotDot} />
      <span className={styles.hotspotLabel}>{item.label}</span>
    </button>
  );
}

function ExteriorScene({ activeId }) {
  const variant = EXTERIOR_VARIANTS[activeId] || EXTERIOR_VARIANTS.restoration;
  const roofLines = Array.from({ length: 9 }, (_, index) => 135 + index * 18);
  const frontSiding = Array.from({ length: 10 }, (_, index) => 255 + index * 16);
  const sideSiding = Array.from({ length: 8 }, (_, index) => 268 + index * 18);

  return (
    <svg
      viewBox="0 0 900 620"
      className={styles.sceneSvg}
      data-service={activeId}
      role="img"
      aria-label="Interactive exterior house service comparison"
    >
      <defs>
        <linearGradient id="ext-bg" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#18243a" />
          <stop offset="100%" stopColor="#0b1426" />
        </linearGradient>
        <radialGradient id="ext-glow" cx="50%" cy="18%" r="60%">
          <stop offset="0%" stopColor="rgba(105, 144, 212, 0.7)" />
          <stop offset="100%" stopColor="rgba(105, 144, 212, 0)" />
        </radialGradient>
        <clipPath id="ext-left">
          <rect x="0" y="0" width="450" height="620" />
        </clipPath>
        <clipPath id="ext-right">
