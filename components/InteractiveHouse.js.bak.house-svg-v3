function InteriorScene({ activeId }) {
  const variant = INTERIOR_VARIANTS[activeId] || INTERIOR_VARIANTS.drywall;
  const backWallLines = Array.from({ length: 8 }, (_, index) => 165 + index * 26);

  return (
    <svg
      viewBox="0 0 900 620"
      className={styles.sceneSvg}
      data-service={activeId}
      role="img"
      aria-label="Interactive interior service comparison"
    >
      <defs>
        <linearGradient id="int-bg" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#192337" />
          <stop offset="100%" stopColor="#0b1322" />
        </linearGradient>
        <radialGradient id="int-glow" cx="50%" cy="20%" r="62%">
          <stop offset="0%" stopColor="rgba(125, 157, 215, 0.55)" />
          <stop offset="100%" stopColor="rgba(125, 157, 215, 0)" />
        </radialGradient>
        <clipPath id="int-left">
          <rect x="0" y="0" width="450" height="620" />
        </clipPath>
        <clipPath id="int-right">
          <rect x="450" y="0" width="450" height="620" />
        </clipPath>
        <clipPath id="int-back-wall">
          <polygon points="185,155 585,155 585,355 185,355" />
        </clipPath>
        <clipPath id="int-floor">
          <polygon points="175,360 590,360 703,435 276,455" />
        </clipPath>
      </defs>

      <g data-piece>
        <rect x="0" y="0" width="900" height="620" rx="34" fill="url(#int-bg)" />
        <ellipse cx="450" cy="140" rx="240" ry="100" fill="url(#int-glow)" opacity="0.72" />
      </g>

      <g data-piece className={styles.houseShadowGroup}>
        <ellipse cx="452" cy="480" rx="238" ry="40" className={styles.houseShadow} />
      </g>

      <g data-piece className={styles.roomVector}>
        <SplitPolygon
          splitId="int"
          points="185,155 585,155 585,355 185,355"
          leftFill={variant.wallLeft}
          rightFill={variant.wallRight}
          className={styles.backWall}
        />
        <SplitPolygon
          splitId="int"
          points="585,155 715,205 715,395 585,355"
          leftFill={variant.sideLeft}
          rightFill={variant.sideRight}
          className={styles.sideRoomWall}
        />
        <SplitPolygon
          splitId="int"
          points="175,360 590,360 703,435 276,455"
          leftFill={variant.floorLeft}
          rightFill={variant.floorRight}
          className={styles.floorPlane}
        />
        <SplitPolygon
          splitId="int"
          points="186,345 587,345 587,360 186,360"
          leftFill={variant.trimLeft}
          rightFill={variant.trimRight}
          className={styles.baseTrim}
        />

        <g clipPath="url(#int-back-wall)">
          {backWallLines.map((y) => (
            <line key={`back-wall-${y}`} x1="178" y1={y} x2="590" y2={y} className={styles.wallLine} />
          ))}
        </g>
        <g clipPath="url(#int-floor)">
          {Array.from({ length: 11 }, (_, index) => (
            <line
              key={`floor-${index}`}
              x1={210 + index * 38}
              y1="362"
              x2={305 + index * 36}
              y2="453"
              className={styles.floorLine}
            />
          ))}
        </g>

        <SplitRect
          splitId="int"
          x="250"
          y="180"
          width="86"
          height="120"
          rx="10"
          leftFill={variant.glassLeft}
          rightFill={variant.glassRight}
          className={styles.showerGlass}
        />
        <SplitRect
          splitId="int"
          x="370"
          y="205"
          width="78"
          height="76"
          rx="8"
          leftFill={variant.moistureLeft}
          rightFill={variant.wallRight}
          className={styles.patchZone}
        />

        <SplitRect
          splitId="int"
          x="536"
          y="205"
          width="82"
          height="88"
          rx="8"
          leftFill={variant.glassLeft}
          rightFill={variant.glassRight}
          className={styles.windowFrame}
        />

        <SplitPolygon
          splitId="int"
          points="490,305 650,305 650,410 490,420"
          leftFill={variant.cabinetLeft}
          rightFill={variant.cabinetRight}
          className={styles.vanityBody}
        />
        <SplitPolygon
          splitId="int"
          points="474,286 660,286 677,305 490,305"
          leftFill={variant.topLeft}
          rightFill={variant.topRight}
          className={styles.counterTop}
        />
        <SplitRect
          splitId="int"
          x="548"
          y="278"
          width="56"
          height="16"
          rx="8"
          leftFill="#e6ecf2"
          rightFill="#ffffff"
          className={styles.sinkBasin}
        />

        <SplitPolygon
          splitId="int"
          points="640,244 708,268 708,365 640,353"
          leftFill={variant.cabinetLeft}
          rightFill={variant.cabinetRight}
          className={styles.sideCabinet}
        />

        <SplitPolygon
          splitId="int"
          points="216,346 304,346 314,458 188,458 196,396"
          leftFill={variant.moistureLeft}
          rightFill={variant.moistureRight}
          className={styles.moistureTrack}
        />

        <line x1="450" y1="150" x2="450" y2="470" className={styles.splitGuide} />
      </g>
    </svg>
  );
}

export default function InteractiveHouse() {
  const [mode, setMode] = useState('exterior');
  const [activeId, setActiveId] = useState(EXTERIOR_HOTSPOTS[0].id);
  const wrapRef = useRef(null);
  const detailRef = useRef(null);

  const hotspots = mode === 'exterior' ? EXTERIOR_HOTSPOTS : INTERIOR_HOTSPOTS;

  const activeHotspot = useMemo(
    () => hotspots.find((item) => item.id === activeId) || hotspots[0],
    [activeId, hotspots]
  );

  const compareState = mode === 'exterior' ? EXTERIOR_VARIANTS[activeId] : INTERIOR_VARIANTS[activeId];

  useEffect(() => {
    setActiveId((mode === 'exterior' ? EXTERIOR_HOTSPOTS : INTERIOR_HOTSPOTS)[0].id);
  }, [mode]);

  useGSAP(
    () => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const pieces = gsap.utils.toArray('[data-piece]');
      const hotspotsEls = gsap.utils.toArray(`.${styles.hotspotBtn}`);

      gsap.fromTo(
        pieces,
        {
          autoAlpha: 0,
          y: (index) => (index % 2 === 0 ? 42 : -32),
          x: (index) => (index % 3 === 0 ? -36 : 28),
          rotate: (index) => (index % 2 === 0 ? -3 : 3),
          scale: 0.92,
          transformOrigin: '50% 50%',
        },
        {
          autoAlpha: 1,
          x: 0,
          y: 0,
          rotate: 0,
          scale: 1,
          duration: 0.78,
          stagger: 0.07,
          ease: 'power3.out',
        }
      );

      gsap.fromTo(
        hotspotsEls,
        { autoAlpha: 0, scale: 0.7, y: 12 },
        {
          autoAlpha: 1,
          scale: 1,
          y: 0,
          duration: 0.42,
          stagger: 0.05,
          ease: 'back.out(1.7)',
          delay: 0.5,
        }
      );

      if (detailRef.current) {
        gsap.fromTo(
          detailRef.current,
          { autoAlpha: 0, y: 16 },
          { autoAlpha: 1, y: 0, duration: 0.42, ease: 'power2.out', delay: 0.4 }
        );
      }
    },
    { scope: wrapRef, dependencies: [mode] }
  );

  useGSAP(
    () => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (!detailRef.current) return;

      gsap.fromTo(
        detailRef.current,
        { autoAlpha: 0.76, y: 10 },
        { autoAlpha: 1, y: 0, duration: 0.28, ease: 'power2.out' }
      );
    },
    { scope: wrapRef, dependencies: [activeId] }
  );

  return (
    <div ref={wrapRef} className={styles.wrap}>
      <div className={styles.modeBtns} role="group" aria-label="House view mode">
        <button
          type="button"
          className={`${styles.modeBtn} ${mode === 'exterior' ? styles.active : ''}`}
          onClick={() => setMode('exterior')}
        >
          Exterior
        </button>
        <button
          type="button"
          className={`${styles.modeBtn} ${mode === 'interior' ? styles.active : ''}`}
          onClick={() => setMode('interior')}
        >
          Interior
        </button>
      </div>

      <div className={styles.sceneWrap}>
        {mode === 'exterior' ? <ExteriorScene activeId={activeId} /> : <InteriorScene activeId={activeId} />}

        <div className={styles.sceneBadge}>{compareState?.badge}</div>
        <div className={styles.sceneStateLeft}>{compareState?.before}</div>
        <div className={styles.sceneStateRight}>{compareState?.after}</div>

        <div className={styles.hotspotLayer}>
          {hotspots.map((item) => (
            <HotspotButton
              key={`${mode}-${item.id}`}
              item={item}
              active={activeId === item.id}
              onActivate={setActiveId}
            />
          ))}
        </div>

        <div className={styles.modeLabel}>
          {mode === 'exterior' ? 'Exterior compare view' : 'Interior compare view'}
        </div>
      </div>

      <div ref={detailRef} className={styles.detailPanel}>
        <div className={styles.detailEyebrow}>{mode === 'exterior' ? 'Exterior service map' : 'Interior service map'}</div>
        <div className={styles.detailRow}>
          <div>
            <h3 className={styles.detailTitle}>{activeHotspot.label}</h3>
            <p className={styles.detailText}>{activeHotspot.description}</p>
          </div>
          <Link href={activeHotspot.href} className={styles.detailLink}>
            View Service
          </Link>
        </div>
        <div className={styles.compareHint}>Left side shows the problem. Right side shows the finished work.</div>
      </div>
    </div>
  );
}
