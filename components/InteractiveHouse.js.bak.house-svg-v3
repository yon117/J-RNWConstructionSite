        </clipPath>
        <clipPath id="ext-front-wall">
          <polygon points="258,250 516,250 516,448 258,448" />
        </clipPath>
        <clipPath id="ext-side-wall">
          <polygon points="516,250 694,207 694,440 516,448" />
        </clipPath>
        <clipPath id="ext-roof-main">
          <polygon points="230,234 446,120 607,199 405,300" />
        </clipPath>
        <clipPath id="ext-roof-side">
          <polygon points="446,120 618,163 770,247 607,199" />
