function HotspotButton({ item, active, onActivate }) {
  return (
    <button
      type="button"
      className={`${styles.hotspotBtn} ${active ? styles.hotspotBtnActive : ''} ${item.tooltipSide === 'left' ? styles.hotspotBtnLeft : ''}`}
      style={{ left: item.x, top: item.y }}
      onMouseEnter={() => onActivate(item.id)}
      onFocus={() => onActivate(item.id)}
      onClick={() => onActivate(item.id)}
      aria-label={item.label}
      aria-pressed={active}
    >
      <span className={styles.hotspotDot} />
      <span className={styles.hotspotTooltip}>
        <span className={styles.hotspotTitle}>{item.label}</span>
        <span className={styles.hotspotDesc}>{item.description}</span>
      </span>
    </button>
  );
}

function ExteriorScene({ activeId, onActivate, onClear }) {
  const activeSrc = activeId ? EXTERIOR_VARIANTS[activeId] : EXTERIOR_VARIANTS.default;

  return (
    <div
      className={styles.sceneVisual}
      onMouseLeave={onClear}
      role="img"
      aria-label="Exterior house service preview"
    >
      <Image
        src={activeSrc}
        alt="Exterior house service preview"
        fill
        priority={false}
        sizes="(max-width: 768px) 100vw, 420px"
        className={styles.sceneImage}
        draggable={false}
      />
      <div className={styles.sceneOverlay} />

      <div className={styles.sceneChip}>{activeId ? activeId.toUpperCase() : 'EXTERIOR'}</div>

      <div className={styles.hotspotLayer}>
        {EXTERIOR_HOTSPOTS.map((item) => (
          <HotspotButton
            key={item.id}
            item={item}
            active={activeId === item.id}
            onActivate={onActivate}
          />
        ))}
      </div>

      <div className={styles.modeLabel}>EXTERIOR SERVICE MAP</div>
    </div>
  );
}

