export default function InteractiveHouse() {
  const [mode, setMode] = useState('exterior');
  const [activeExteriorId, setActiveExteriorId] = useState('');
  const [activeInteriorId, setActiveInteriorId] = useState('');

  const hotspots = mode === 'exterior' ? EXTERIOR_HOTSPOTS : INTERIOR_HOTSPOTS;
  const activeId = mode === 'exterior' ? activeExteriorId : activeInteriorId;

  const activeHotspot = useMemo(
    () => hotspots.find((item) => item.id === activeId) || hotspots[0],
    [activeId, hotspots]
  );

  function changeMode(nextMode) {
    setMode(nextMode);
  }

  return (
    <div className={styles.wrap}>
      <div className={styles.modeBtns} role="group" aria-label="House view mode">
        <button
          type="button"
          className={`${styles.modeBtn} ${mode === 'exterior' ? styles.active : ''}`}
          onClick={() => changeMode('exterior')}
        >
          Exterior
        </button>
        <button
          type="button"
          className={`${styles.modeBtn} ${mode === 'interior' ? styles.active : ''}`}
          onClick={() => changeMode('interior')}
        >
          Interior
        </button>
      </div>

      <div className={styles.sceneWrap}>
        {mode === 'exterior' ? (
          <ExteriorScene
            activeId={activeExteriorId}
            onActivate={setActiveExteriorId}
            onClear={() => setActiveExteriorId('')}
          />
        ) : (
          <div
            className={styles.sceneVisual}
            aria-label="Interior room service preview"
            onMouseLeave={() => setActiveInteriorId('')}
          >
            <InteriorScene />
            <div className={styles.sceneOverlay} />
            <div className={styles.sceneChip}>{activeId ? activeHotspot.label.toUpperCase() : 'INTERIOR'}</div>
            <div className={styles.hotspotLayer}>
              {hotspots.map((item) => (
                <HotspotButton
                  key={`${mode}-${item.id}`}
                  item={item}
                  active={activeInteriorId === item.id}
                  onActivate={setActiveInteriorId}
                />
              ))}
            </div>
            <div className={styles.modeLabel}>INTERIOR SERVICE MAP</div>
          </div>
        )}
      </div>
    </div>
  );
}
